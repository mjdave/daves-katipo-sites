# clientSite/scripts/code.tui
# this code is downloaded by the client when they first connect and is run on the client browser. It is the entirety of the waraki client "app"
# It handles the user interface and all client interactions, as well as requesting music from the host

editPlaylistUI = require("scripts/editPlaylistUI.tui")

songsCachePath = file.getSavePath("files/songs/")

file.createDirectoriesIfNeededForDirPath(songsCachePath)

print("songsCachePath:", songsCachePath)

paused = true
connected = false

allRequiredSongPaths = {}
filesToRemove = false
fileRemoveComplete = false
downloadsComplete = false
cleanupComplete = false

songDownloadArray = {}
songsToDownloadByID = {}
currentRequestedSongDownloadInfo = false

sharedPlaylistsByPlaylistID = false
directoryTree = false

playbackURLQueue = {}

getSongCallback = function(result, hostID)
{
    downloadInfo = currentRequestedSongDownloadInfo
    .currentRequestedSongDownloadInfo = nil
    print("site code got result with status:", result.status, " message:", result.message, " hostID:", hostID)
    if(!result or result.status != "ok")
    {
        if(result and result.message == "not connected")
        {
            statusSubtitleTextView.text = "Not connected"
            .connected = false
            #addDownload(downloadInfo.songInfo, downloadInfo.playWhenDone) #for now we just give up on this download and keep trying the rest. Restart the app to try again.
        }
        else
        {
            print("failed to download. skipping file.")
        }
    }
    else if(result.songID and result.fileData and result.fileName)
    {
        print("cache song downloaded: ", result.fileName)

        songInfo = downloadInfo.songInfo
        thisSongCachePath = songsCachePath + songInfo.localPath
        file.createDirectoriesIfNeededForFilePath(thisSongCachePath)
        file.saveData(thisSongCachePath, result.fileData)

        statusSubtitleTextView.text = " "
        
        if(downloadInfo.playWhenDone)
        {
            table.insert(playbackURLQueue, 0, thisSongCachePath)
            audio.queueSongs(playbackURLQueue)
            print("playing when done:", playbackURLQueue)
            .paused = false
            updatePauseButton()
            audio.playSongs()
        }
    }
    else
    {
        error("unhandled result.")
    }
}

checkForNextFileAndDownloadIfNeeded = function()
{
    downloadInfo = songDownloadArray[0]
    table.remove(songDownloadArray, 0)

    songInfo = downloadInfo.songInfo
    thisSongCachePath = songsCachePath + songInfo.localPath

    if(file.fileExists(thisSongCachePath))
    {
        statusSubtitleTextView.text = "Syncing..."
        return false
    }
    
    print("downloading song:", songInfo.fileName)
    statusSubtitleTextView.text = "Downloading: " + songInfo.fileName
    .currentRequestedSongDownloadInfo = downloadInfo
    
    katipo.get("songs/" + songInfo.songID, getSongCallback)
    return true
}


updateDownloads = function()
{
    if(!currentRequestedSongDownloadInfo)
    {
        if(table.count(songDownloadArray) > 0)
        {
            .downloadsComplete = false
            
            for(i = 0, i < 32, i++) #this limits the number of file operations per frame, should really be done on a background thread
            {
                startedDownload = checkForNextFileAndDownloadIfNeeded()
                if(startedDownload or table.count(songDownloadArray) == 0)
                {
                    break
                }
            }
        }
        else
        {
            statusSubtitleTextView.text = "Sync Complete."
            .downloadsComplete = true
        }
    }
}

recursivelyAddFilesToRemove = function(localPath)
{
    thisSongCachePath = songsCachePath
    if(localPath)
    {
        thisSongCachePath += localPath
    }
    if(file.isDirectory(thisSongCachePath))
    {
        contents = file.directoryContents(thisSongCachePath)
        for(fileName in contents)
        {
            fullLocalPath = fileName
            if(localPath)
            {
                fullLocalPath = localPath + "/" + fileName
            }
            recursivelyAddFilesToRemove(fullLocalPath)
        }
    }
    else
    {
        if(file.fileExists(thisSongCachePath))
        {
            if(!allRequiredSongPaths[localPath])
            {
                table.insert(filesToRemove, localPath)
            }
        }
    }
}

updateCleanup = function()
{
    if(downloadsComplete and !cleanupComplete)
    {
        if(!filesToRemove)
        {
            .filesToRemove = {}
            recursivelyAddFilesToRemove()
            #print("filesToRemove:", filesToRemove)
        }

        removeCount = table.count(filesToRemove)
        if(removeCount == 0)
        {
            .cleanupComplete = true
        }
        else
        {
            localPath = filesToRemove[removeCount - 1]
            if(!allRequiredSongPaths[localPath])
            {
                fullPath = songsCachePath + localPath
                print("removing file:", fullPath)
                file.remove(fullPath)
            }
            table.remove(filesToRemove, removeCount - 1)
        }
    }
}

addDownload = function(songInfo, playWhenDone)
{
    if(currentRequestedSongDownloadInfo and currentRequestedSongDownloadInfo.songInfo.songID == songInfo.songID)
    {
        return #already requested
    }

    if(songsToDownloadByID[songInfo.songID])
    {
        if(playWhenDone) #prioritize if playWhenDone
        {
            if(songDownloadArray[0].songInfo.songID != songInfo.songID)
            {
                for(i,downloadInfo in songDownloadArray)
                {
                    if(downloadInfo.songInfo.songID == songInfo.songID)
                    {
                        table.remove(songDownloadArray, i)
                        break
                    }
                }
            }
        }
        else
        {
            return #already in download queue
        }
    }
    
    downloadInfo = {
        songInfo = songInfo
        playWhenDone = playWhenDone
    }

    songPath = songInfo.localPath
    allRequiredSongPaths[songPath] = true
    
    songsToDownloadByID[songInfo.songID] = downloadInfo

    if(playWhenDone)
    {
        table.insert(songDownloadArray, 0, downloadInfo) #insert first
    }
    else
    {
        table.insert(songDownloadArray, downloadInfo) #insert last
    }

}

katipo.update = function(dt) #called every tick
{
    if(connected)
    {
        updateDownloads()
    }
    updateCleanup()
}

titleView = scene.getView("title")
subtitleView = scene.getView("subtitle")

statusSubtitleTextView = scene.getView("statusText")
playlistContentView = scene.getView("playlistContent")
playlistScrollView = scene.getView("playlistScrollView")

settingsButton = scene.getView("settingsButton")
addPlaylistButton = scene.getView("addPlaylistButton")

settingsBackButton = scene.getView("settingsBackButton")

playPauseButton = scene.getView("playPauseButton")
nextButton = scene.getView("nextButton")

playlistsHeader = scene.getView("playlistsHeader")
settingsHeader = scene.getView("settingsHeader")
editPlaylistHeader = scene.getView("editPlaylistHeader")

settingsContent = scene.getView("settingsContent")
editPlaylistContent = scene.getView("editPlaylistContent")


settingsButton.click = function()
{
    playlistsHeader.hidden = true
    playlistContentView.hidden = true

    settingsHeader.hidden = false
    settingsContent.hidden = false
}

editPlaylistBackClick = function()
{
    playlistsHeader.hidden = false
    playlistContentView.hidden = false

    loadPlaylists()

    editPlaylistHeader.hidden = true
    editPlaylistContent.hidden = true
}

playPreview = function(songInfo)
{
    thisSongCachePath = songsCachePath + songInfo.localPath

    if(!file.fileExists(thisSongCachePath))
    {
        addDownload(songInfo, true)
    }
    else
    {
        .playbackURLQueue = {}
        table.insert(playbackURLQueue, thisSongCachePath)
        audio.queueSongs(playbackURLQueue)
        .paused = false
        updatePauseButton()
        audio.playSongs()
    }
}

addPlaylistButton.click = function()
{
    playlistsHeader.hidden = true
    playlistContentView.hidden = true
    
    editPlaylistHeader.hidden = false
    editPlaylistContent.hidden = false

    editPlaylistUI.show(directoryTree, nil)
}

settingsBackButton.click = function()
{
    playlistsHeader.hidden = false
    playlistContentView.hidden = false

    settingsHeader.hidden = true
    settingsContent.hidden = true
}



updatePauseButton = function()
{
    if(paused)
    {
        playPauseButton.path = "images/play.png"
    }
    else
    {
        playPauseButton.path = "images/pause.png"
    }
}

playPauseButtonClick = function()
{
    .paused = !paused
    paused = .paused #tui bug
    if(paused)
    {
        #print("pause stopping audio")
        audio.stop()
    }
    else
    {
        #print("pause starting audio")
        playSelectedPlaylist()
    }
    updatePauseButton()
}

playPauseButton.click = playPauseButtonClick

nextButton.click = function()
{
    audio.next()
}

playlistViews = {}
selectedPlaylistView = false
shouldResumeSelectedPlaylist = false

updateVisuals = function()
{
    for(itemView in playlistViews)
    {
        backgroundView = itemView.getView("playlistItemBackground")
        if(itemView == selectedPlaylistView)
        {
            backgroundView.setSelected(true)
        }
        else
        {
            backgroundView.setSelected(false)
        }
    }
}

selectedPlaylist = false

playSelectedPlaylist = function()
{
    if(!selectedPlaylistView)
    {
        playlistCount = table.count(playlistViews)
        if(playlistCount > 0)
        {
            randomIndex = math.randomInt(playlistCount)
            .selectedPlaylistView = playlistViews[randomIndex]
            updateVisuals()
        }
        else
        {
            return
        }
    }

    if(selectedPlaylist == selectedPlaylistView.playlist)
    {
        .paused = false
        updatePauseButton()
        audio.playSongs()
    }
    else
    {
        .selectedPlaylist = selectedPlaylistView.playlist
        .playbackURLQueue = {}

        for(songInfo in selectedPlaylist.songs)
        {
            thisSongCachePath = songsCachePath + songInfo.localPath
            if(file.fileExists(thisSongCachePath))
            {
                table.insert(playbackURLQueue, thisSongCachePath)
            }
            else
            {
                print("error, file not found:", thisSongCachePath)
            }
        }

        if(table.count(playbackURLQueue) > 0)
        {
            table.shuffle(playbackURLQueue)
            print("playbackURLQueue:", playbackURLQueue)
            audio.queueSongs(playbackURLQueue)
            .paused = false
            updatePauseButton()
            audio.playSongs()
        }
    }
}

audio.playingSongChanged = function(title, artist, duration)
{
    print("got song changed:", title, " artist:", artist)
    titleView.text = title
    subtitleView.text = artist
}


audio.playingSongPausedChanged = function(newPaused)
{
    .paused = newPaused
    updatePauseButton()
}

addSongsToDownloadQueueForPlaylist = function(playlist)
{
    if(playlist and playlist.songs)
    {
        for(songInfo in playlist.songs)
        {
            addDownload(songInfo, false)
        }
    }
}

loadPlaylists = function()
{
    sharedPlaylistsOrderedArray = {}

    if(sharedPlaylistsByPlaylistID)
    {
        for(playlistID,playlistData in sharedPlaylistsByPlaylistID)
        {
            table.insert(sharedPlaylistsOrderedArray, playlistData)
        }
    }

    compareFunction = function(a,b)
    {
        return a.name < b.name
    }
    table.sort(sharedPlaylistsOrderedArray, compareFunction)

    .playlistViews = {}
    playlistScrollView.removeAllRows()

    noPlaylistsText = scene.getView("noPlaylistsText")

    if(table.count(sharedPlaylistsOrderedArray) > 0)
    {
        noPlaylistsText.hidden = true

        viewTable = scene.mainPlaylistsPlaylistItem

        for(i,playlist in sharedPlaylistsOrderedArray)
        {
            disabledKey = "disabled_" + playlist.playlistID
            playlistDownloadDisabled = database.get(disabledKey)
            if(!playlistDownloadDisabled)
            {
                addSongsToDownloadQueueForPlaylist(playlist)
            }
            else
            {
                print("skipping download of disabled playlist:", playlist.name)
            }

            itemView = playlistScrollView.addView(viewTable)
            titleTextView = itemView.getView("playlistItemTitle")
            titleTextView.text = playlist.name
            itemView.playlist = playlist

            backgroundView = itemView.getView("playlistItemBackground")

            dotDotDotButton = itemView.getView("dotDotDotButton")
            dotDotDotButton.setHueOffset(-0.1 * i + 0.2)
            dotDotDotButton.click = function()
            {
                playlistsHeader.hidden = true
                playlistContentView.hidden = true
                
                editPlaylistHeader.hidden = false
                editPlaylistContent.hidden = false
                editPlaylistUI.show(directoryTree, playlist)
            }

            playFunc = function()
            {
                .selectedPlaylistView = itemView
                playSelectedPlaylist()
                updateVisuals()

            }

            backgroundView.click = function()
            {
                playFunc()
            }

            if(i % 2 == 0)
            {
                backgroundView.color = backgroundView.color * 0.5
            }
            backgroundView.baseColor = backgroundView.color
            itemView.baseColor = backgroundView.color

            backgroundView.selectedColor = itemView.baseColor + vec4(0.2,0.0,0.5,0.3)

            #playlistScrollView.insertRow(itemView)
            table.insert(playlistViews, itemView)
        }
    }
    else
    {
        noPlaylistsText.hidden = false
    }      
}

savePlaylist = function(serverPlaylistInfo)
{
    saveCallback = function()
    {
        #todo if this fails we need to save the fact it has changed in the database, send again in the future 
    }

    if(serverPlaylistInfo.songs and table.count(serverPlaylistInfo.songs) > 0)
    {
        sharedPlaylistsByPlaylistID[serverPlaylistInfo.playlistID] = serverPlaylistInfo
    }
    else
    {
        sharedPlaylistsByPlaylistID[serverPlaylistInfo.playlistID] = nil
    }

    #database.set("sharedPlaylists", sharedPlaylistsByPlaylistID)
    katipo.get("savePlaylist", serverPlaylistInfo, saveCallback)
}


editPlaylistUI.delegate = { #expose public functions to editPlaylistUI via "delegate"
    playPreview = playPreview
    playPauseButtonClick = playPauseButtonClick
    backButtonClicked = editPlaylistBackClick
    savePlaylist = savePlaylist
}

katipo.onSiteLoad = function(wasNewDownload, publicData) #wasNewDownload if we just pulled an update of the site. false if we are running from the cache, but now have a connection
{
    #print("in katipo.onSiteLoad. database:", database)
    if(publicData)
    {
        .connected = true
        .sharedPlaylistsByPlaylistID = publicData.sharedPlaylists
        .directoryTree = publicData.directoryTree
        database.set("sharedPlaylists", sharedPlaylistsByPlaylistID)
        database.set("directoryTree", directoryTree)
    }
    else
    {
        .connected = false
        .sharedPlaylistsByPlaylistID = database.get("sharedPlaylists")
        .directoryTree = database.get("directoryTree")

        #print("sharedPlaylistsByPlaylistID:", sharedPlaylistsByPlaylistID)
    }

    loadPlaylists()
}